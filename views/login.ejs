<div class="container fade-in">
  <div class="auth-card panel">
    <h2 class="text-center mb-4">Welcome Back</h2>
    
    <% if (error_msg && error_msg.length > 0) { %>
      <div class="alert alert-danger" style="color: var(--error); background: #fef2f2; border: 1px solid var(--error); padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem;">
        <%= error_msg %>
      </div>
    <% } %>
    
    <% if (success_msg && success_msg.length > 0) { %>
      <div class="alert alert-success" style="color: var(--success); background: #ecfdf5; border: 1px solid var(--success); padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem;">
        <%= success_msg %>
      </div>
    <% } %>

    <form action="/login" method="POST">
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" name="email" id="email" class="form-control" required placeholder="you@example.com">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" name="password" id="password" class="form-control" required placeholder="Enter your password">
      </div>
      <button type="submit" class="btn" style="width: 100%; margin-top: 1rem;">Log In</button>
    </form>
    
    <div class="text-center" style="margin-top: 2rem;">
      <p style="color: var(--text-secondary);">Don't have an account? <a href="/signup">Sign up</a></p>
    </div>
  </div>
</div>
