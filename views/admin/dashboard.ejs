<h2 style="margin-bottom:2rem; font-family:'Playfair Display', serif;">Dashboard</h2>

<div class="bento-grid fade-in stagger-1">
  <div class="bento-card stat-card">
    <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
    <div class="stat-info">
      <h3><%= stats.posts %></h3>
      <p>Total Posts</p>
    </div>
  </div>
  <div class="bento-card stat-card stagger-2">
    <div class="stat-icon"><i class="fas fa-eye"></i></div>
    <div class="stat-info">
      <h3><%= stats.views %></h3>
      <p>Total Views</p>
    </div>
  </div>
  <div class="bento-card stat-card stagger-3">
    <div class="stat-icon"><i class="fas fa-comments"></i></div>
    <div class="stat-info">
      <h3><%= stats.pendingComments %></h3>
      <p>Pending Comments</p>
    </div>
  </div>
</div>

<div class="grid-layout fade-in stagger-2">
  <div class="bento-card">
    <h3 style="margin-top:0;">Welcome to QALAM THIRASH Admin</h3>
    <p style="color:var(--admin-text-light); margin-top:1rem; margin-bottom:0;">Use the sidebar to navigate and manage your content efficiently.</p>
  </div>
</div>
