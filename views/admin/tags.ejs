<h2 style="margin-bottom:2rem; font-family:'Playfair Display', serif;">Tags</h2>

<div class="grid-layout">
  <div>
    <div class="glass glass-panel">
      <h3 style="margin-bottom:1.5rem;">Add New Tag</h3>
      <form action="/admin/tags/new" method="POST">
        <div class="form-group">
          <label>Name (Malayalam/English)</label>
          <input type="text" name="name" class="form-control" required>
        </div>
        <div class="form-group">
          <label>Custom Slug (Optional)</label>
          <input type="text" name="slug" class="form-control" placeholder="Leave empty to auto-generate">
        </div>
        <button type="submit" class="btn" style="width:100%;">Save Tag</button>
      </form>
    </div>
  </div>

  <div>
    <div class="glass glass-panel admin-table-container">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Slug</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% tags.forEach(t => { %>
            <tr>
              <td><%= t.name %></td>
              <td><%= t.slug %></td>
              <td>
                <form action="/admin/tags/delete/<%= t.id %>" method="POST" style="display:inline;" onsubmit="return confirm('Delete tag?')">
                  <button type="submit" class="btn btn-secondary" style="padding:0.4rem 0.6rem; color:var(--error);" title="Delete"><i class="fas fa-trash"></i></button>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if(tags.length === 0) { %>
            <tr>
              <td colspan="3" class="text-center">No tags found.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
