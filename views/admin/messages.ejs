<h2 style="margin-bottom:2rem; font-family:'Playfair Display', serif;">Messages</h2>

<div class="glass glass-panel admin-table-container">
  <table class="admin-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Message</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% messages.forEach(m => { %>
        <tr>
          <td><%= m.name %></td>
          <td><a href="mailto:<%= m.email %>" style="color:var(--text-primary);"><%= m.email %></a></td>
          <td style="max-width:300px;"><p style="font-size:0.9rem; margin:0;"><%= m.message %></p></td>
          <td><%= new Date(m.created_at).toLocaleString() %></td>
          <td>
            <a href="mailto:<%= m.email %>?subject=Reply%20from%20Malayalam%20Blog" class="btn btn-secondary" style="padding:0.3rem 0.5rem;" title="Reply"><i class="fas fa-reply"></i></a>
            <!-- Delete form could go here, for now it's simple -->
          </td>
        </tr>
      <% }) %>
      <% if(messages.length === 0) { %>
        <tr>
          <td colspan="5" class="text-center">No messages found.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
