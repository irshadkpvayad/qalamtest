<h2 style="margin-bottom:2rem; font-family:'Playfair Display', serif;">Subscribers</h2>

<div class="grid-layout">
  <div>
    <div class="glass glass-panel">
      <h3 style="margin-bottom:1.5rem;">Broadcast Email</h3>
      <form action="/admin/subscribers/broadcast" method="POST">
        <div class="form-group">
          <label>Subject</label>
          <input type="text" name="subject" class="form-control" required>
        </div>
        <div class="form-group">
          <label>Message (HTML Allowed)</label>
          <textarea id="content" name="message" class="form-control" rows="8"></textarea>
        </div>
        <button type="submit" class="btn" style="width:100%;" onclick="return confirm('Send email to all active subscribers? This might take a while depending on the number of subscribers.')">Send Broadcast</button>
      </form>
    </div>
  </div>

  <div>
    <div class="glass glass-panel admin-table-container">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Email</th>
            <th>Status</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% subscribers.forEach(s => { %>
            <tr>
              <td><%= s.email %></td>
              <td><span class="badge badge-<%= s.is_active ? 'published' : 'draft' %>"><%= s.is_active ? 'Active' : 'Unsubscribed' %></span></td>
              <td><%= new Date(s.subscribed_at).toLocaleDateString() %></td>
            </tr>
          <% }) %>
          <% if(subscribers.length === 0) { %>
            <tr>
              <td colspan="3" class="text-center">No subscribers found.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
