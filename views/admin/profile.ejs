<h2 style="margin-bottom:2rem; font-family:'Playfair Display', serif;">Profile</h2>

<form action="/admin/profile" method="POST">
  <div class="glass glass-panel" style="max-width:600px;">
    <div class="form-group">
      <label>Email (Cannot be changed here)</label>
      <input type="email" class="form-control" value="<%= profile.email || user.email %>" disabled>
    </div>
    <div class="form-group">
      <label>Display Name</label>
      <input type="text" name="display_name" class="form-control" value="<%= profile.display_name || '' %>" required>
    </div>
    <div class="form-group">
      <label>Bio</label>
      <textarea name="bio" class="form-control" rows="4"><%= profile.bio || '' %></textarea>
    </div>
    <div class="form-group">
      <label>Avatar URL</label>
      <input type="text" name="avatar_url" class="form-control" value="<%= profile.avatar_url || '' %>" placeholder="Optional image URL">
    </div>
    <!-- Social Links can be added similarly -->
    <button type="submit" class="btn">Update Profile</button>
  </div>
</form>
