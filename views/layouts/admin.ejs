<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Quill.js CDN for Rich Text Editing -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="admin-overlay" id="adminOverlay"></div>
    <div class="admin-layout">
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="admin-brand">
                QALAM THIRASH<br><small>Admin Panel</small>
            </div>
            <ul class="admin-nav">
                <li><a href="/admin/dashboard"><i class="fas fa-home"></i> Dashboard</a></li>
                <li><a href="/admin/posts"><i class="fas fa-file-alt"></i> Posts</a></li>
                <li><a href="/admin/categories"><i class="fas fa-folder"></i> Categories</a></li>
                <li><a href="/admin/tags"><i class="fas fa-tags"></i> Tags</a></li>
                <li><a href="/admin/media"><i class="fas fa-images"></i> Media</a></li>
                <li><a href="/admin/comments"><i class="fas fa-comments"></i> Comments</a></li>
                <li><a href="/admin/subscribers"><i class="fas fa-users"></i> Subscribers</a></li>
                <li><a href="/admin/messages"><i class="fas fa-envelope"></i> Messages</a></li>
                <li><a href="/admin/settings"><i class="fas fa-cog"></i> Settings</a></li>
                <li><a href="/admin/profile"><i class="fas fa-user"></i> Profile</a></li>
            </ul>
        </aside>
        <main class="admin-main">
            <header class="admin-topbar">
                <button class="admin-mobile-toggle" id="adminMenuBtn">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="ui-text">Welcome, <%= user ? user.name || user.email : 'Admin' %></div>
                <div style="display:flex; gap:0.5rem; flex-wrap:wrap; justify-content:flex-end;">
                    <a href="/" target="_blank" class="btn btn-secondary"><i class="fas fa-external-link-alt"></i> <span class="hide-mobile">View Site</span></a>
                    <a href="/logout" class="btn"><i class="fas fa-sign-out-alt"></i> <span class="hide-mobile">Logout</span></a>
                </div>
            </header>
            <div class="admin-content fade-in">
                <% if(success_msg && success_msg.length > 0){ %>
                  <div class="bento-card" style="border-left: 4px solid var(--admin-success); margin-bottom:1.5rem; padding: 1rem 1.5rem; color: var(--admin-success); background: #ecfdf5;">
                    <i class="fas fa-check-circle" style="margin-right: 0.5rem;"></i> <%= success_msg %>
                  </div>
                <% } %>
                <% if(error_msg && error_msg.length > 0){ %>
                  <div class="bento-card" style="border-left: 4px solid var(--admin-danger); margin-bottom:1.5rem; padding: 1rem 1.5rem; color: var(--admin-danger); background: #fef2f2;">
                    <i class="fas fa-exclamation-circle" style="margin-right: 0.5rem;"></i> <%= error_msg %>
                  </div>
                <% } %>
                <%- body %>
            </div>
        </main>
    </div>
    
    <style>
      @media (max-width: 480px) {
        .hide-mobile { display: none; }
      }
    </style>
    
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const adminBtn = document.getElementById('adminMenuBtn');
        const adminSidebar = document.getElementById('adminSidebar');
        const adminOverlay = document.getElementById('adminOverlay');
        
        function toggleAdminDrawer() {
          adminSidebar.classList.toggle('open');
          adminOverlay.classList.toggle('active');
        }
        
        if (adminBtn) adminBtn.addEventListener('click', toggleAdminDrawer);
        if (adminOverlay) adminOverlay.addEventListener('click', toggleAdminDrawer);
      });
    </script>
    <script src="/js/admin.js"></script>
</body>
</html>
