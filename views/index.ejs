<div class="container fade-in stagger-1">
  <% if (posts.length === 0) { %>
    <div class="panel text-center">
      <p>No posts found.</p>
    </div>
  <% } else { %>
    
    <% if (currentPage === 1 && posts[0]) { %>
      <!-- Premium Hero Featured Post -->
      <div class="hero-section fade-in">
        <% if (posts[0].featured_image) { %>
          <img src="<%= posts[0].featured_image %>" alt="<%= posts[0].title %>" class="hero-img">
        <% } else { %>
          <div style="background: #101828; width: 100%; height: 100%; position: absolute; z-index: 0;"></div>
        <% } %>
        <div class="hero-overlay"></div>
        <div class="hero-content">
          <div class="hero-text-side">
            <span class="hero-badge">Featured Post</span>
            <h2 class="hero-title ml-text" style="font-family:'Playfair Display', serif; font-size:2.25rem;">
              <a href="/post/<%= posts[0].slug %>" style="color: #fff;"><%= posts[0].title %></a>
            </h2>
            <p class="hero-subtitle ml-text" style="color: #eaecf0; font-size: 1rem; line-height: 1.6; margin-top: 0.5rem;">
              <%= posts[0].excerpt || (posts[0].content ? posts[0].content.replace(/<[^>]*>?/gm, '').substring(0, 140) + '...' : '') %>
            </p>
          </div>
          <a href="/post/<%= posts[0].slug %>" class="hero-arrow" title="Read Article">
            <i class="fas fa-arrow-right"></i>
          </a>
        </div>
      </div>
    <% } %>

    <!-- Grid Layout -->
    <div class="post-grid fade-in stagger-2">
      <% posts.forEach((post, index) => { %>
        <% if (currentPage === 1 && index === 0) return; // Skip featured %>
        <%- include('partials/post-card', { post }) %>
        
        <% if (sliderImages && sliderImages.length > 0 && ((currentPage === 1 && index === 6) || (currentPage > 1 && index === 5))) { %>
          </div> <!-- Close post-grid -->
          
          <!-- Swiper Slider Section -->
          <div class="homepage-slider-container" style="margin: 3.5rem 0; width: 100%; grid-column: 1 / -1;">
            <h3 style="margin-bottom:1.5rem; text-align:center; font-family:'Playfair Display', serif; color:var(--text-primary);">Media Showcase</h3>
            <div class="swiper homepage-slider" style="border-radius: 16px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.08); height: 400px; background:#f8fafc;">
              <div class="swiper-wrapper">
                <% sliderImages.forEach(img => { %>
                  <div class="swiper-slide">
                    <img src="<%= img.url %>" style="width: 100%; height: 100%; object-fit: cover;" alt="Slider Image">
                  </div>
                <% }) %>
              </div>
              <div class="swiper-pagination"></div>
              <div class="swiper-button-next" style="color: #fff; background: rgba(0,0,0,0.3); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size:1rem;"></div>
              <div class="swiper-button-prev" style="color: #fff; background: rgba(0,0,0,0.3); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size:1rem;"></div>
            </div>
          </div>
          
          <div class="post-grid"> <!-- Reopen post-grid -->
        <% } %>
      <% }) %>
    </div>

    <!-- Swiper Initialization -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        new Swiper('.homepage-slider', {
          loop: true,
          autoplay: {
            delay: 3500,
            disableOnInteraction: false,
          },
          pagination: {
            el: '.swiper-pagination',
            clickable: true,
          },
          navigation: {
            nextEl: '.swiper-button-next',
            prevEl: '.swiper-button-prev',
          },
        });
      });
    </script>

    <%- include('partials/pagination', { currentPage, totalPages }) %>
  <% } %>
</div>
