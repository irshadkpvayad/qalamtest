<article class="post-card fade-in">
  <div class="post-card-img-wrap">
    <% if (post.featured_image) { %>
      <a href="/post/<%= post.slug %>">
        <img src="<%= post.featured_image %>" alt="<%= post.title %>" class="post-card-img" loading="lazy">
      </a>
    <% } else { %>
      <div style="background: #101828; width:100%; height:100%; display: flex; align-items: center; justify-content: center;">
        <i class="fas fa-image fa-3x" style="color: rgba(255,255,255,0.2);"></i>
      </div>
    <% } %>
  </div>
  
  <div class="post-card-content">
    <div class="post-meta">
      <span>QALAM THIRASH</span> &bull; 
      <span><%= new Date(post.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
    </div>
    
    <h3 class="post-title">
      <a href="/post/<%= post.slug %>" class="ml-text"><%= post.title %></a>
    </h3>
    
    <p class="post-excerpt ml-text">
      <%= post.excerpt || (post.content ? post.content.replace(/<[^>]*>?/gm, '').substring(0, 100) + '...' : '') %>
    </p>
    
    <div class="author-info" style="display:flex; align-items:center; gap:0.75rem; margin-top: auto; padding-top: 1rem; border-top: 1px solid #eaecf0;">
      <% if (post.profiles && post.profiles.avatar_url) { %>
        <img src="<%= post.profiles.avatar_url %>" alt="<%= post.profiles.display_name %>" style="width:32px; height:32px; border-radius:50%; object-fit:cover;">
      <% } else { %>
        <div style="width:32px; height:32px; border-radius:50%; background:#f2f4f7; display:flex; align-items:center; justify-content:center; color:#667085;">
          <i class="fas fa-user" style="font-size:0.8rem;"></i>
        </div>
      <% } %>
      <span style="font-size:0.85rem; font-weight:600; color:#344054;">
        <%= post.profiles ? post.profiles.display_name : 'Author' %>
      </span>
    </div>
  </div>
</article>
