<article class="single-post fade-in container" data-post-id="<%= post.id %>" style="max-width: 1200px; padding-top: 2rem;">
  <header class="single-post-header">
    <% if(tags && tags.length > 0) { %>
      <div style="margin-bottom:1.5rem;">
        <% tags.forEach(tag => { %>
          <a href="/tag/<%= tag.slug %>" class="post-tag" style="text-decoration:none; margin-right:0.5rem;"><%= tag.name %></a>
        <% }) %>
      </div>
    <% } %>
    
    <h1 class="single-post-title ml-text"><%= post.title %></h1>
    
    <div class="post-meta post-meta-bar">
      <span><i class="fas fa-user" style="color:var(--accent);"></i> <%= post.profiles ? post.profiles.display_name : 'Admin' %></span>
      <span>
        <i class="fas fa-calendar" style="color:var(--accent);"></i> 
        <%= new Date(post.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
      </span>
      <span><i class="fas fa-eye" style="color:var(--accent);"></i> <%= post.views %> Views</span>
      <span id="read-time-display"><i class="fas fa-clock" style="color:var(--accent);"></i> <%= Math.ceil(post.content.split(/\s+/).length / 150) %> Min Read</span>
    </div>
  </header>

  <% if(post.featured_image) { %>
    <img src="<%= post.featured_image %>" alt="<%= post.title %>" class="single-post-img">
  <% } %>

  <div class="grid-layout">
    <div class="post-content panel ml-text">
      <%- post.content %>
      
      <div class="like-btn-container">
        <form action="/like/<%= post.id %>" method="POST" class="ajax-form">
          <button type="submit" class="like-btn <%= isLiked ? 'liked' : '' %>" <%= !user ? 'disabled title="Login to like"' : '' %>>
            <i class="<%= isLiked ? 'fas' : 'far' %> fa-heart"></i>
          </button>
        </form>
        <div>
          <strong style="color: var(--text-primary); font-size: 1.1rem;"><span id="likes-count"><%= likesCount || 0 %></span> Likes</strong>
          <p style="color: var(--text-secondary); font-size: 0.9rem; margin:0;">
            <% if(user) { %>Did you enjoy this article?<% } else { %>Log in to like this article.<% } %>
          </p>
        </div>
      </div>

      <!-- Social Sharing Session -->
      <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border-color);">
        <h4 style="margin-bottom: 1.5rem; color: var(--text-primary); font-family: 'Playfair Display', serif; font-size: 1.25rem;"><i class="fas fa-share-alt"></i> Share this Article</h4>
        <div style="display: flex; gap: 0.8rem; flex-wrap: wrap;">
          <a id="share-facebook" href="#" target="_blank" class="btn" style="background: #1877f2; color: #fff; border: none; display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; font-size:0.9rem;" title="Share on Facebook">
            <i class="fab fa-facebook-f"></i> Facebook
          </a>
          <a id="share-twitter" href="#" target="_blank" class="btn" style="background: #111; color: #fff; border: none; display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; font-size:0.9rem;" title="Share on Twitter/X">
            <i class="fab fa-twitter"></i> Twitter
          </a>
          <a id="share-whatsapp" href="#" target="_blank" class="btn" style="background: #25d366; color: #fff; border: none; display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; font-size:0.9rem;" title="Share on WhatsApp">
            <i class="fab fa-whatsapp"></i> WhatsApp
          </a>
          <button id="share-copy" class="btn btn-secondary" style="display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; font-size:0.9rem;" title="Copy Link">
            <i class="fas fa-link"></i> Copy Link
          </button>
        </div>
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const url = encodeURIComponent(window.location.href);
          const title = encodeURIComponent(document.title);
          document.getElementById('share-facebook').href = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
          document.getElementById('share-twitter').href = `https://twitter.com/intent/tweet?text=${title}&url=${url}`;
          document.getElementById('share-whatsapp').href = `https://api.whatsapp.com/send?text=${title}%20${url}`;
          document.getElementById('share-copy').addEventListener('click', () => {
            navigator.clipboard.writeText(window.location.href).then(() => {
              alert('Link copied to clipboard!');
            });
          });
        });
      </script>
    </div>
    
    <div class="sidebar" style="display:flex; flex-direction:column; gap:2rem;">
      <!-- Author Bio -->
      <div class="panel" style="text-align:center;">
        <% if(post.profiles && post.profiles.avatar_url) { %>
          <img src="<%= post.profiles.avatar_url %>" alt="Author" style="width:80px; height:80px; border-radius:50%; margin-bottom:1rem; object-fit: cover;">
        <% } else { %>
          <div style="width:80px; height:80px; border-radius:50%; background:var(--border-color); margin:0 auto 1rem auto; display:flex; align-items:center; justify-content:center;">
            <i class="fas fa-user fa-2x" style="color: var(--text-secondary);"></i>
          </div>
        <% } %>
        <h3><%= post.profiles ? post.profiles.display_name : 'Admin' %></h3>
        <p style="font-size:0.9rem; color:var(--text-secondary); margin-bottom: 0;">Content Editor</p>
        <% if(post.profiles && post.profiles.bio) { %>
          <p style="font-size:0.9rem; color:var(--text-secondary); margin-top: 1rem;"><%= post.profiles.bio %></p>
        <% } %>
      </div>

      <!-- Categories Widget -->
      <div class="panel">
        <h4 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.5rem;"><i class="fas fa-folder" style="color:var(--accent);"></i> Categories</h4>
        <ul style="list-style: none; padding-left: 0; margin:0;">
          <% topCategories.forEach(cat => { %>
            <li style="padding: 0.6rem 0; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
              <a href="/category/<%= cat.slug %>" style="color: var(--text-primary); font-weight: 500;"><%= cat.name %></a>
              <span style="font-size: 0.8rem; background: #f1f5f9; padding: 0.2rem 0.5rem; border-radius: 9999px; color: var(--text-secondary);"><%= cat.post_count || 0 %></span>
            </li>
          <% }) %>
        </ul>
      </div>

      <!-- Popular Posts Widget -->
      <div class="panel">
        <h4 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.5rem;"><i class="fas fa-fire" style="color:var(--accent);"></i> Popular Articles</h4>
        <ul style="list-style: none; padding-left: 0; margin:0; display:flex; flex-direction:column; gap:1rem;">
          <% popularPosts.forEach(p => { %>
            <li style="display: flex; gap: 0.75rem; align-items: center;">
              <% if (p.featured_image) { %>
                <img src="<%= p.featured_image %>" style="width: 50px; height: 50px; border-radius: 6px; object-fit: cover;" alt="<%= p.title %>">
              <% } %>
              <div style="flex: 1; min-width: 0;">
                <a href="/post/<%= p.slug %>" style="color: var(--text-primary); font-weight: 600; font-size: 0.9rem; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= p.title %></a>
                <span style="font-size: 0.75rem; color: var(--text-secondary);"><%= p.views %> views</span>
              </div>
            </li>
          <% }) %>
        </ul>
      </div>

      <!-- Newest Articles Widget -->
      <div class="panel">
        <h4 style="border-bottom: 1px solid var(--border-color); padding-bottom: 0.5rem; margin-bottom: 1.5rem;"><i class="fas fa-clock" style="color:var(--accent);"></i> Newest Articles</h4>
        <ul style="list-style: none; padding-left: 0; margin:0; display:flex; flex-direction:column; gap:1rem;">
          <% recentPosts.forEach(p => { %>
            <li style="display: flex; gap: 0.75rem; align-items: center;">
              <% if (p.featured_image) { %>
                <img src="<%= p.featured_image %>" style="width: 50px; height: 50px; border-radius: 6px; object-fit: cover;" alt="<%= p.title %>">
              <% } %>
              <div style="flex: 1; min-width: 0;">
                <a href="/post/<%= p.slug %>" style="color: var(--text-primary); font-weight: 600; font-size: 0.9rem; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= p.title %></a>
                <span style="font-size: 0.75rem; color: var(--text-secondary);"><%= new Date(p.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span>
              </div>
            </li>
          <% }) %>
        </ul>
      </div>

      <!-- Table of Contents -->
      <div class="panel" id="toc-container" style="display:none;">
        <h4>Table of Contents</h4>
        <ul id="toc-list" style="list-style:none; padding-left:0; margin-top:1rem;"></ul>
      </div>
    </div>
  </div>
</article>

<div class="floating-actions fade-in stagger-2">
  <a href="https://api.whatsapp.com/send?text=<%= encodeURIComponent(post.title + ' ' + 'http://yourdomain.com/post/' + post.slug) %>" target="_blank" class="float-btn whatsapp-btn" title="Share on WhatsApp">
    <i class="fab fa-whatsapp"></i>
  </a>
</div>

<% if(post.allow_comments) { %>
<section class="comments-section fade-in stagger-3 container" style="margin-top:4rem; max-width:900px; padding-bottom: 4rem;">
  <h3 style="border-bottom: 2px solid var(--accent); display: inline-block; padding-bottom: 0.5rem; margin-bottom: 2rem;">Comments (<%= comments.length %>)</h3>
  
  <div class="panel" style="margin-bottom:3rem;">
    <h4>Leave a Comment</h4>
    <% if(user) { %>
      <form action="/comment" method="POST" class="ajax-form" style="margin-top:1.5rem;">
        <input type="hidden" name="post_id" value="<%= post.id %>">
        <div class="form-group">
          <textarea name="content" class="form-control" rows="4" placeholder="Share your thoughts..." required style="resize: vertical;"></textarea>
        </div>
        <button type="submit" class="btn">Post Comment</button>
      </form>
    <% } else { %>
      <div style="background: #f8fafc; padding: 2rem; border-radius: 8px; text-align: center; margin-top: 1.5rem; border: 1px dashed var(--border-color);">
        <p style="color: var(--text-secondary); margin-bottom: 1rem;">You must be logged in to post a comment.</p>
        <a href="/login" class="btn">Log In</a>
        <a href="/signup" class="btn btn-secondary" style="margin-left: 0.5rem;">Sign Up</a>
      </div>
    <% } %>
  </div>

  <div class="comments-list" style="display:flex; flex-direction:column; gap:1.5rem;">
    <% if(comments.length === 0) { %>
      <p style="color: var(--text-secondary); text-align: center;">No comments yet. Be the first to share your thoughts!</p>
    <% } %>
    
    <% comments.forEach(comment => { %>
      <div class="comment panel">
        <div style="display:flex; justify-content:space-between; margin-bottom:1rem;">
          <div style="display: flex; align-items: center; gap: 0.8rem;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: #e2e8f0; display: flex; align-items: center; justify-content: center; color: var(--text-secondary); font-weight: 600;">
              <%= (comment.profiles && comment.profiles.display_name ? comment.profiles.display_name.charAt(0).toUpperCase() : 'U') %>
            </div>
            <strong><%= comment.profiles ? comment.profiles.display_name : 'User' %></strong>
          </div>
          <span style="font-size:0.85rem; color:var(--text-secondary);">
            <%= new Date(comment.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
          </span>
        </div>
        <p class="ml-text" style="color: #334155; margin-left: 3.5rem;"><%= comment.content %></p>
      </div>
    <% }) %>
  </div>
</section>
<% } %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Generate Table of Contents
  const content = document.querySelector('.post-content');
  const headings = content.querySelectorAll('h2, h3');
  
  if (headings.length > 0) {
    const tocContainer = document.getElementById('toc-container');
    const tocList = document.getElementById('toc-list');
    
    headings.forEach((heading, index) => {
      const id = 'heading-' + index;
      heading.id = id;
      
      const li = document.createElement('li');
      li.style.marginBottom = '0.8rem';
      if(heading.tagName === 'H3') {
        li.style.paddingLeft = '1rem';
      }
      
      const a = document.createElement('a');
      a.href = '#' + id;
      a.textContent = heading.textContent;
      a.style.color = 'var(--text-secondary)';
      a.style.fontSize = '0.95rem';
      
      li.appendChild(a);
      tocList.appendChild(li);
    });
    
    tocContainer.style.display = 'block';
  }
});
</script>
